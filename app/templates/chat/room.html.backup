{% extends "base.html" %}

{% block content %}
<div class="chat-room-container">
    <!-- Water Background Elements -->
    <div class="water-background">
        <div class="water-surface"></div>
        <div class="water-bubbles">
            <div class="bubble bubble-1"></div>
            <div class="bubble bubble-2"></div>
            <div class="bubble bubble-3"></div>
            <div class="bubble bubble-4"></div>
            <div class="bubble bubble-5"></div>
        </div>
        <div class="light-rays">
            <div class="ray ray-1"></div>
            <div class="ray ray-2"></div>
            <div class="ray ray-3"></div>
        </div>
    </div>

    <!-- Chat Header -->
    <div class="chat-room-header">
        <a href="{{ url_for('chat.index') }}" class="back-button">
            <i class="fas fa-arrow-left"></i>
        </a>
        
        <div class="chat-partner-info">
            <div class="partner-avatar">
                {% if other_user.profile_picture %}
                    <img src="{{ other_user.profile_picture }}" alt="{{ other_user.username }}">
                {% else %}
                    <div class="avatar-placeholder">
                        {{ other_user.username[0]|upper }}
                    </div>
                {% endif %}
                <div class="online-indicator"></div>
            </div>
            <div class="partner-details">
                <h2>{{ other_user.username }}</h2>
                <p class="product-info">
                    <i class="fas fa-tag"></i> {{ product.title }}
                    <span class="product-price">KES {{ product.price }}</span>
                </p>
            </div>
        </div>
        
        <div class="chat-actions">
            <button class="chat-action-btn" onclick="toggleWaterEffects()" title="Toggle Water Effects">
                <i class="fas fa-water"></i>
            </button>
            <button class="chat-action-btn" onclick="clearAllMessages()" title="Clear All Messages">
                <i class="fas fa-trash"></i>
            </button>
        </div>
    </div>

    <!-- Messages Container -->
    <div class="messages-container" id="messagesContainer">
        <div class="messages-scroll" id="messagesScroll">
            <div class="messages-list" id="messagesList">
                {% for message in messages %}
                <div class="message-wrapper {% if message.sender_id == current_user.id %}outgoing-wrapper{% else %}incoming-wrapper{% endif %}"
                     data-message-id="{{ message.id }}"
                     data-type="{{ 'image' if message.is_image else 'text' }}">
                    <div class="message {% if message.sender_id == current_user.id %}message-outgoing{% else %}message-incoming{% endif %}"
                         style="animation-delay: {{ loop.index * 0.1 }}s;">
                        <div class="message-content">
                            {% if message.is_image %}
                            <div class="message-image">
                                <img src="{{ message.get_image_url() }}" alt="Chat image" 
                                     onclick="viewImage('{{ message.get_image_url() }}')">
                                <div class="image-overlay">
                                    <button class="delete-btn" onclick="deleteMessage({{ message.id }}, this)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                    <button class="download-btn" onclick="downloadImage('{{ message.get_image_url() }}')">
                                        <i class="fas fa-download"></i>
                                    </button>
                                </div>
                                {% if message.content %}
                                <p class="image-caption">{{ message.content }}</p>
                                {% endif %}
                            </div>
                            {% else %}
                            <p class="message-text">{{ message.content }}</p>
                            <button class="delete-btn text-delete" onclick="deleteMessage({{ message.id }}, this)">
                                <i class="fas fa-times"></i>
                            </button>
                            {% endif %}
                            <div class="message-time">
                                <span class="time">{{ message.formatted_time }}</span>
                                {% if message.sender_id == current_user.id %}
                                <i class="fas {% if message.is_read %}fa-check-double read{% else %}fa-check{% endif %}"></i>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <!-- Message Input -->
    <div class="message-input-container">
        <form id="messageForm" class="message-form">
            <div class="input-group">
                <button type="button" class="attach-btn" id="attachBtn" title="Attach image">
                    <i class="fas fa-image"></i>
                </button>
                
                <input type="file" id="imageInput" accept="image/*" style="display: none;">
                
                <div class="text-input-wrapper">
                    <textarea id="messageInput" placeholder="Type your message..." 
                             rows="1" maxlength="1000"></textarea>
                    <div class="input-ripple"></div>
                    <span class="char-counter" id="charCounter">0/1000</span>
                </div>
                
                <button type="submit" class="send-btn" id="sendBtn" title="Send message">
                    <i class="fas fa-paper-plane"></i>
                    <div class="send-ripple"></div>
                </button>
            </div>
        </form>
        
        <div class="typing-indicator" id="typingIndicator" style="display: none;">
            <div class="typing-dots">
                <span class="dot dot-1"></span>
                <span class="dot dot-2"></span>
                <span class="dot dot-3"></span>
            </div>
            <span>{{ other_user.username }} is typing...</span>
        </div>
    </div>

    <!-- Wave Effect Container -->
    <div class="wave-effect" id="waveEffect"></div>
</div>

<style>
    :root {
        --ig-bg: #000000;
        --ig-card-bg: #121212;
        --ig-surface: #1e1e1e;
        --ig-border: #262626;
        --ig-text: #ffffff;
        --ig-text-secondary: #a8a8a8;
        --ig-primary: #0095f6;
        --ig-purple: #405DE6;
        --ig-blue: #5851DB;
        --ig-pink: #E1306C;
        --ig-red: #FD1D1D;
        --ig-orange: #FCAF45;
        --ig-yellow: #FFDC80;
        --ig-gradient: linear-gradient(45deg, #405DE6, #5851DB, #833AB4, #C13584, #E1306C, #FD1D1D);
        --water-color: rgba(0, 149, 246, 0.1);
        --water-deep: rgba(64, 93, 230, 0.15);
        --water-surface: rgba(131, 58, 180, 0.2);
    }

    .chat-room-container {
        max-width: 800px;
        margin: 0 auto;
        height: calc(100vh - 140px);
        display: flex;
        flex-direction: column;
        background: linear-gradient(180deg, var(--ig-bg) 0%, #0a0a0a 100%);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        position: relative;
        isolation: isolate;
    }

    /* Water Background */
    .water-background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        overflow: hidden;
        opacity: 0.6;
    }

    .water-surface {
        position: absolute;
        top: 0;
        left: 0;
        width: 200%;
        height: 100%;
        background: linear-gradient(90deg, 
            transparent 0%, 
            var(--water-surface) 50%, 
            transparent 100%);
        animation: waterFlow 20s linear infinite;
    }

    .water-bubbles {
        position: absolute;
        width: 100%;
        height: 100%;
    }

    .bubble {
        position: absolute;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%, 
            rgba(64, 93, 230, 0.4), 
            rgba(0, 149, 246, 0.2));
        filter: blur(1px);
        animation: floatBubble 15s infinite ease-in-out;
    }

    .bubble-1 { width: 60px; height: 60px; top: 10%; left: 10%; animation-delay: 0s; }
    .bubble-2 { width: 40px; height: 40px; top: 30%; left: 80%; animation-delay: 2s; }
    .bubble-3 { width: 70px; height: 70px; top: 60%; left: 20%; animation-delay: 4s; }
    .bubble-4 { width: 30px; height: 30px; top: 80%; left: 60%; animation-delay: 6s; }
    .bubble-5 { width: 50px; height: 50px; top: 40%; left: 90%; animation-delay: 8s; }

    .light-rays {
        position: absolute;
        width: 100%;
        height: 100%;
    }

    .ray {
        position: absolute;
        background: linear-gradient(90deg, 
            transparent 0%, 
            rgba(255, 255, 255, 0.1) 50%, 
            transparent 100%);
        filter: blur(10px);
        transform-origin: left;
        animation: lightRay 20s infinite linear;
    }

    .ray-1 { width: 200px; height: 2px; top: 20%; left: -200px; animation-delay: 0s; }
    .ray-2 { width: 150px; height: 1px; top: 50%; left: -150px; animation-delay: 7s; }
    .ray-3 { width: 250px; height: 3px; top: 80%; left: -250px; animation-delay: 14s; }

    /* Chat Header */
    .chat-room-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background: rgba(18, 18, 18, 0.9);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--ig-border);
        flex-shrink: 0;
        z-index: 10;
    }

    .back-button {
        color: var(--ig-text);
        font-size: 1.2rem;
        text-decoration: none;
        padding: 0.5rem;
        border-radius: 50%;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.1);
    }

    .back-button:hover {
        background: var(--ig-primary);
        transform: translateX(-3px);
    }

    .chat-partner-info {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex: 1;
        margin: 0 1rem;
    }

    .partner-avatar {
        position: relative;
    }

    .partner-avatar img {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--ig-primary);
        box-shadow: 0 0 20px rgba(0, 149, 246, 0.3);
    }

    .avatar-placeholder {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: var(--ig-gradient);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        font-size: 1.2rem;
        border: 2px solid var(--ig-primary);
        box-shadow: 0 0 20px rgba(0, 149, 246, 0.3);
    }

    .online-indicator {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 12px;
        height: 12px;
        background: #34d399;
        border: 2px solid var(--ig-bg);
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    .partner-details h2 {
        color: var(--ig-text);
        font-size: 1.1rem;
        margin: 0 0 0.25rem 0;
        font-weight: 600;
    }

    .product-info {
        color: var(--ig-text-secondary);
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .product-price {
        color: var(--ig-orange);
        font-weight: 600;
    }

    .chat-actions {
        display: flex;
        gap: 0.5rem;
    }

    .chat-action-btn {
        background: rgba(255, 255, 255, 0.1);
        border: none;
        color: var(--ig-text);
        font-size: 1.2rem;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .chat-action-btn:hover {
        background: var(--ig-gradient);
        transform: scale(1.1);
        box-shadow: 0 0 20px rgba(0, 149, 246, 0.4);
    }

    /* Messages Container */
    .messages-container {
        flex: 1;
        overflow: hidden;
        position: relative;
        background: transparent;
    }

    .messages-scroll {
        height: 100%;
        overflow-y: auto;
        padding: 1.5rem;
        scroll-behavior: smooth;
        position: relative;
    }

    .messages-scroll::-webkit-scrollbar {
        width: 8px;
    }

    .messages-scroll::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 4px;
    }

    .messages-scroll::-webkit-scrollbar-thumb {
        background: var(--ig-gradient);
        border-radius: 4px;
    }

    .messages-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        min-height: 100%;
        justify-content: flex-end;
    }

    /* Message Animations */
    .message-wrapper {
        position: relative;
        transform-origin: center;
    }

    .outgoing-wrapper {
        align-self: flex-end;
    }

    .incoming-wrapper {
        align-self: flex-start;
    }

    .message {
        max-width: 75%;
        position: relative;
        opacity: 0;
        transform: translateY(20px) scale(0.95);
        animation: floatIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    .message-outgoing {
        animation-name: floatInRight;
    }

    .message-incoming {
        animation-name: floatInLeft;
    }

    .message-content {
        padding: 1rem 1.25rem;
        border-radius: 20px;
        position: relative;
        word-wrap: break-word;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
    }

    .message-outgoing .message-content {
        background: linear-gradient(135deg, rgba(0, 149, 246, 0.9), rgba(64, 93, 230, 0.9));
        color: white;
        border-bottom-right-radius: 8px;
        box-shadow: 0 8px 25px rgba(0, 149, 246, 0.3);
    }

    .message-incoming .message-content {
        background: linear-gradient(135deg, rgba(30, 30, 30, 0.9), rgba(38, 38, 38, 0.9));
        color: var(--ig-text);
        border-bottom-left-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }

    .message:hover .message-content {
        transform: translateY(-2px);
    }

    .message-text {
        margin: 0;
        line-height: 1.4;
        font-size: 0.95rem;
        position: relative;
        padding-right: 25px;
    }

    .delete-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        background: rgba(0, 0, 0, 0.5);
        border: none;
        color: var(--ig-text);
        width: 24px;
        height: 24px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        opacity: 0;
        transition: all 0.3s ease;
        z-index: 2;
    }

    .text-delete {
        top: -10px;
        right: -10px;
        background: var(--ig-red);
    }

    .message:hover .delete-btn {
        opacity: 1;
        transform: scale(1.1);
    }

    .delete-btn:hover {
        background: var(--ig-red);
        transform: scale(1.2) !important;
    }

    .message-image {
        margin: -0.5rem -0.75rem;
        border-radius: 15px;
        overflow: hidden;
        position: relative;
    }

    .message-image img {
        max-width: 100%;
        max-height: 300px;
        display: block;
        cursor: pointer;
        transition: transform 0.5s ease;
    }

    .message-image:hover img {
        transform: scale(1.05);
    }

    .image-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .message-image:hover .image-overlay {
        opacity: 1;
    }

    .image-overlay button {
        background: rgba(255, 255, 255, 0.2);
        border: none;
        color: white;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

    .image-overlay button:hover {
        background: var(--ig-primary);
        transform: scale(1.1);
    }

    .image-caption {
        padding: 1rem;
        margin: 0;
        font-size: 0.9rem;
        color: var(--ig-text);
        background: rgba(0, 0, 0, 0.7);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .message-time {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.5rem;
        margin-top: 0.5rem;
        font-size: 0.75rem;
        opacity: 0.8;
    }

    .message-time i.read {
        color: var(--ig-yellow);
    }

    /* Message Input */
    .message-input-container {
        padding: 1.5rem;
        background: rgba(18, 18, 18, 0.9);
        backdrop-filter: blur(10px);
        border-top: 1px solid var(--ig-border);
        flex-shrink: 0;
        z-index: 10;
    }

    .message-form {
        margin-bottom: 0.5rem;
    }

    .input-group {
        display: flex;
        align-items: flex-end;
        gap: 1rem;
        position: relative;
    }

    .attach-btn,
    .send-btn {
        background: var(--ig-gradient);
        border: none;
        color: white;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        transition: all 0.3s ease;
        flex-shrink: 0;
        position: relative;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 149, 246, 0.3);
    }

    .attach-btn:hover,
    .send-btn:hover {
        transform: scale(1.05) rotate(5deg);
        box-shadow: 0 8px 25px rgba(0, 149, 246, 0.5);
    }

    .attach-btn:active,
    .send-btn:active {
        transform: scale(0.95);
    }

    .send-ripple {
        position: absolute;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.5);
        transform: scale(0);
        animation: ripple 0.6s linear;
    }

    .text-input-wrapper {
        flex: 1;
        position: relative;
        background: rgba(30, 30, 30, 0.8);
        border-radius: 25px;
        padding: 0.5rem;
        border: 2px solid transparent;
        transition: all 0.3s ease;
    }

    .text-input-wrapper:focus-within {
        border-color: var(--ig-primary);
        box-shadow: 0 0 30px rgba(0, 149, 246, 0.2);
    }

    #messageInput {
        width: 100%;
        padding: 0.75rem 1rem;
        background: transparent;
        border: none;
        color: white;
        font-family: inherit;
        font-size: 0.95rem;
        resize: none;
        max-height: 120px;
        min-height: 50px;
        line-height: 1.4;
        outline: none;
    }

    #messageInput::placeholder {
        color: var(--ig-text-secondary);
    }

    .input-ripple {
        position: absolute;
        border-radius: 50%;
        background: rgba(0, 149, 246, 0.3);
        transform: scale(0);
        pointer-events: none;
    }

    .char-counter {
        position: absolute;
        bottom: 0.5rem;
        right: 0.75rem;
        font-size: 0.75rem;
        color: var(--ig-text-secondary);
    }

    /* Typing Indicator */
    .typing-indicator {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: rgba(30, 30, 30, 0.8);
        border-radius: 15px;
        backdrop-filter: blur(10px);
    }

    .typing-dots {
        display: flex;
        gap: 0.25rem;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--ig-primary);
        animation: typing 1.4s infinite ease-in-out;
    }

    .dot-1 { animation-delay: -0.32s; }
    .dot-2 { animation-delay: -0.16s; }
    .dot-3 { animation-delay: 0s; }

    /* Wave Effect */
    .wave-effect {
        position: absolute;
        bottom: 80px;
        left: 0;
        width: 100%;
        height: 20px;
        pointer-events: none;
        opacity: 0;
        z-index: 5;
    }

    .wave-effect::before {
        content: '';
        position: absolute;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, 
            transparent 0%, 
            rgba(0, 149, 246, 0.3) 50%, 
            transparent 100%);
        filter: blur(5px);
        animation: waveExpand 1s ease-out forwards;
    }

    /* Animations */
    @keyframes waterFlow {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }

    @keyframes floatBubble {
        0%, 100% { 
            transform: translateY(0) rotate(0deg);
            opacity: 0.5;
        }
        50% { 
            transform: translateY(-20px) rotate(180deg);
            opacity: 1;
        }
    }

    @keyframes lightRay {
        0% { transform: translateX(0) scaleX(0); }
        50% { transform: translateX(50vw) scaleX(1); }
        100% { transform: translateX(100vw) scaleX(0); }
    }

    @keyframes floatIn {
        0% {
            opacity: 0;
            transform: translateY(20px) scale(0.95);
        }
        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @keyframes floatInRight {
        0% {
            opacity: 0;
            transform: translateX(20px) translateY(20px) scale(0.95);
        }
        100% {
            opacity: 1;
            transform: translateX(0) translateY(0) scale(1);
        }
    }

    @keyframes floatInLeft {
        0% {
            opacity: 0;
            transform: translateX(-20px) translateY(20px) scale(0.95);
        }
        100% {
            opacity: 1;
            transform: translateX(0) translateY(0) scale(1);
        }
    }

    @keyframes ripple {
        to {
            transform: scale(4);
            opacity: 0;
        }
    }

    @keyframes typing {
        0%, 60%, 100% { transform: translateY(0); }
        30% { transform: translateY(-6px); }
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.7; transform: scale(1.1); }
    }

    @keyframes waveExpand {
        0% { 
            transform: scaleX(0);
            opacity: 1;
        }
        100% { 
            transform: scaleX(1);
            opacity: 0;
        }
    }

    @keyframes deleteAnimation {
        0% {
            transform: scale(1);
            opacity: 1;
        }
        50% {
            transform: scale(1.1);
            opacity: 0.7;
        }
        100% {
            transform: scale(0);
            opacity: 0;
        }
    }

    /* Responsive Design */
    @media (max-width: 768px) {
        .chat-room-container {
            height: 100vh;
            border-radius: 0;
            margin: 0;
        }

        .chat-room-header {
            padding: 1rem;
        }

        .partner-avatar img,
        .avatar-placeholder {
            width: 40px;
            height: 40px;
        }

        .message {
            max-width: 85%;
        }

        .messages-scroll {
            padding: 1rem;
        }

        .message-input-container {
            padding: 1rem;
        }

        .attach-btn,
        .send-btn {
            width: 45px;
            height: 45px;
        }
    }

    @media (max-width: 480px) {
        .chat-room-header {
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .chat-partner-info {
            order: 2;
            width: 100%;
            justify-content: center;
            margin: 0.5rem 0;
        }

        .message {
            max-width: 90%;
        }

        .delete-btn {
            opacity: 1;
        }
    }
</style>

<!-- Image Modal -->
<div class="image-modal" id="imageModal">
    <button class="image-modal-close" onclick="closeImageModal()">
        <i class="fas fa-times"></i>
    </button>
    <div class="modal-content">
        <img id="modalImage" src="" alt="Full size image">
        <div class="modal-actions">
            <button onclick="downloadImage(document.getElementById('modalImage').src)">
                <i class="fas fa-download"></i> Download
            </button>
            <button onclick="shareImage()">
                <i class="fas fa-share"></i> Share
            </button>
        </div>
    </div>
</div>

<script>
    const chatId = {{ chat.id }};
    let lastMessageId = {{ messages[-1].id if messages else 0 }};
    let isTyping = false;
    let typingTimeout = null;
    let waterEffectsEnabled = true;
    
    document.addEventListener('DOMContentLoaded', function() {
        const messagesContainer = document.getElementById('messagesContainer');
        const messagesScroll = document.getElementById('messagesScroll');
        const messagesList = document.getElementById('messagesList');
        const messageForm = document.getElementById('messageForm');
        const messageInput = document.getElementById('messageInput');
        const charCounter = document.getElementById('charCounter');
        const attachBtn = document.getElementById('attachBtn');
        const imageInput = document.getElementById('imageInput');
        const sendBtn = document.getElementById('sendBtn');
        const typingIndicator = document.getElementById('typingIndicator');
        const waveEffect = document.getElementById('waveEffect');
        
        // Initialize water effects
        initWaterEffects();
        
        // Auto-resize textarea with ripple effect
        messageInput.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
            
            // Update character counter
            const length = this.value.length;
            charCounter.textContent = `${length}/1000`;
            
            if (length >= 950) {
                charCounter.style.color = 'var(--ig-red)';
            } else if (length >= 800) {
                charCounter.style.color = 'var(--ig-orange)';
            } else {
                charCounter.style.color = 'var(--ig-text-secondary)';
            }
            
            // Typing indicator
            if (!isTyping && this.value.length > 0) {
                isTyping = true;
                typingIndicator.style.display = 'inline-flex';
            }
            
            clearTimeout(typingTimeout);
            typingTimeout = setTimeout(() => {
                isTyping = false;
                typingIndicator.style.display = 'none';
            }, 1000);
        });
        
        // Add ripple effect on input focus
        messageInput.addEventListener('focus', function(e) {
            const wrapper = this.closest('.text-input-wrapper');
            const ripple = wrapper.querySelector('.input-ripple');
            if (ripple) {
                ripple.style.left = (e.clientX - wrapper.getBoundingClientRect().left) + 'px';
                ripple.style.top = (e.clientY - wrapper.getBoundingClientRect().top) + 'px';
                ripple.style.width = ripple.style.height = '100px';
                ripple.style.opacity = '1';
                ripple.style.transform = 'scale(0)';
                
                setTimeout(() => {
                    ripple.style.transform = 'scale(2)';
                    ripple.style.opacity = '0';
                }, 10);
            }
        });
        
        // Scroll to bottom
        function scrollToBottom() {
            messagesScroll.scrollTop = messagesScroll.scrollHeight;
        }
        
        setTimeout(scrollToBottom, 100);
        
        // Attach image button
        attachBtn.addEventListener('click', () => imageInput.click());
        
        imageInput.addEventListener('change', function(e) {
            if (this.files && this.files[0]) {
                sendMessage(null, this.files[0]);
                this.value = '';
            }
        });
        
        // Send message with animation
        messageForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const content = messageInput.value.trim();
            if (content) {
                sendMessage(content);
                messageInput.value = '';
                messageInput.style.height = 'auto';
                charCounter.textContent = '0/1000';
                charCounter.style.color = 'var(--ig-text-secondary)';
                
                // Create ripple effect on send button
                const ripple = sendBtn.querySelector('.send-ripple');
                ripple.style.left = '50%';
                ripple.style.top = '50%';
                ripple.style.width = ripple.style.height = '10px';
                ripple.style.marginLeft = '-5px';
                ripple.style.marginTop = '-5px';
                ripple.style.opacity = '1';
                ripple.style.transform = 'scale(0)';
                ripple.style.animation = 'none';
                
                setTimeout(() => {
                    ripple.style.animation = 'ripple 0.6s linear';
                }, 10);
            }
        });
        
        // Send message function
        async function sendMessage(content = null, imageFile = null) {
            const formData = new FormData();
            if (content) formData.append('content', content);
            if (imageFile) formData.append('image', imageFile);
            
            sendBtn.disabled = true;
            sendBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            
            try {
                const response = await fetch(`/chat/${chatId}/send`, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });
                
                const data = await response.json();
                
                if (data.success) {
                    // Show wave effect
                    showWaveEffect();
                    
                    // Add message with animation
                    setTimeout(() => {
                        addMessage(data, true);
                        lastMessageId = data.message_id;
                        scrollToBottom();
                    }, 300);
                } else {
                    showAlert('Error', data.error || 'Failed to send message', 'error');
                }
            } catch (error) {
                console.error('Error sending message:', error);
                showAlert('Error', 'Failed to send message. Please try again.', 'error');
            } finally {
                sendBtn.disabled = false;
                sendBtn.innerHTML = '<i class="fas fa-paper-plane"></i>';
            }
        }
        
        // Add message with water animation
        function addMessage(data, isOutgoing = false) {
            const wrapper = document.createElement('div');
            wrapper.className = `message-wrapper ${isOutgoing ? 'outgoing-wrapper' : 'incoming-wrapper'}`;
            wrapper.dataset.messageId = data.message_id;
            wrapper.dataset.type = data.is_image ? 'image' : 'text';
            
            const time = new Date(data.created_at).toLocaleTimeString([], { 
                hour: '2-digit', 
                minute: '2-digit' 
            });
            
            let contentHtml = '';
            if (data.is_image) {
                contentHtml = `
                    <div class="message-image">
                        <img src="${data.image_url}" alt="Chat image" onclick="viewImage('${data.image_url}')">
                        <div class="image-overlay">
                            <button class="delete-btn" onclick="deleteMessage(${data.message_id}, this)">
                                <i class="fas fa-trash"></i>
                            </button>
                            <button class="download-btn" onclick="downloadImage('${data.image_url}')">
                                <i class="fas fa-download"></i>
                            </button>
                        </div>
                        ${data.content ? `<p class="image-caption">${data.content}</p>` : ''}
                    </div>
                `;
            } else {
                contentHtml = `
                    <p class="message-text">${data.content}</p>
                    <button class="delete-btn text-delete" onclick="deleteMessage(${data.message_id}, this)">
                        <i class="fas fa-times"></i>
                    </button>
                `;
            }
            
            wrapper.innerHTML = `
                <div class="message ${isOutgoing ? 'message-outgoing' : 'message-incoming'}">
                    <div class="message-content">
                        ${contentHtml}
                        <div class="message-time">
                            <span class="time">${time}</span>
                            ${isOutgoing ? '<i class="fas fa-check"></i>' : ''}
                        </div>
                    </div>
                </div>
            `;
            
            messagesList.appendChild(wrapper);
            
            // Trigger water ripple effect
            if (waterEffectsEnabled) {
                createMessageRipple(wrapper, isOutgoing);
            }
        }
        
        // Create ripple effect for new message
        function createMessageRipple(wrapper, isOutgoing) {
            const message = wrapper.querySelector('.message');
            const rect = message.getBoundingClientRect();
            
            const ripple = document.createElement('div');
            ripple.style.position = 'fixed';
            ripple.style.width = '100px';
            ripple.style.height = '100px';
            ripple.style.background = 'radial-gradient(circle, rgba(0,149,246,0.3) 0%, transparent 70%)';
            ripple.style.borderRadius = '50%';
            ripple.style.pointerEvents = 'none';
            ripple.style.zIndex = '1';
            
            if (isOutgoing) {
                ripple.style.right = '20px';
                ripple.style.bottom = rect.bottom + 'px';
            } else {
                ripple.style.left = '20px';
                ripple.style.bottom = rect.bottom + 'px';
            }
            
            document.body.appendChild(ripple);
            
            ripple.animate([
                { transform: 'scale(0)', opacity: 1 },
                { transform: 'scale(3)', opacity: 0 }
            ], {
                duration: 1000,
                easing: 'ease-out'
            });
            
            setTimeout(() => ripple.remove(), 1000);
        }
        
        // Show wave effect
        function showWaveEffect() {
            if (!waterEffectsEnabled) return;
            
            waveEffect.style.opacity = '1';
            waveEffect.animate([
                { opacity: 1, transform: 'scaleX(0)' },
                { opacity: 0, transform: 'scaleX(1)' }
            ], {
                duration: 1000,
                easing: 'ease-out'
            });
            
            setTimeout(() => {
                waveEffect.style.opacity = '0';
            }, 1000);
        }
        
        // Poll for new messages
        async function pollForNewMessages() {
            try {
                const response = await fetch(`/chat/${chatId}/messages?last_id=${lastMessageId}`);
                const data = await response.json();
                
                if (data.messages && data.messages.length > 0) {
                    data.messages.forEach(msg => {
                        if (msg.id > lastMessageId) {
                            addMessage(msg, msg.is_mine);
                            lastMessageId = msg.id;
                            
                            // Show wave effect for incoming messages
                            if (!msg.is_mine) {
                                showWaveEffect();
                            }
                        }
                    });
                    
                    if (data.messages.some(msg => !msg.is_mine)) {
                        scrollToBottom();
                    }
                }
            } catch (error) {
                console.error('Error polling messages:', error);
            }
        }
        
        // Poll every 3 seconds
        setInterval(pollForNewMessages, 3000);
        
        // Handle enter key
        messageInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                messageForm.dispatchEvent(new Event('submit'));
            }
        });
        
        // Update unread count when leaving
        window.addEventListener('beforeunload', function() {
            fetch(`/chat/${chatId}/mark_read`);
        });
        
        // Initialize bubbles animation
        initBubbles();
    });
    
    // Toggle water effects
    function toggleWaterEffects() {
        waterEffectsEnabled = !waterEffectsEnabled;
        const waterBg = document.querySelector('.water-background');
        
        if (waterEffectsEnabled) {
            waterBg.style.opacity = '0.6';
            showAlert('Water Effects', 'Water effects enabled!', 'success');
        } else {
            waterBg.style.opacity = '0';
            showAlert('Water Effects', 'Water effects disabled.', 'info');
        }
    }
    
    // Initialize water effects
    function initWaterEffects() {
        // Add floating particles
        for (let i = 0; i < 20; i++) {
            const particle = document.createElement('div');
            particle.className = 'water-particle';
            particle.style.cssText = `
                position: absolute;
                width: ${Math.random() * 4 + 1}px;
                height: ${Math.random() * 4 + 1}px;
                background: rgba(0, 149, 246, ${Math.random() * 0.3 + 0.1});
                border-radius: 50%;
                left: ${Math.random() * 100}%;
                top: ${Math.random() * 100}%;
                animation: floatBubble ${Math.random() * 20 + 10}s infinite ease-in-out;
                animation-delay: ${Math.random() * 5}s;
            `;
            document.querySelector('.water-background').appendChild(particle);
        }
    }
    
    // Initialize bubbles
    function initBubbles() {
        const bubbles = document.querySelectorAll('.bubble');
        bubbles.forEach(bubble => {
            bubble.style.animationDuration = `${Math.random() * 10 + 10}s`;
        });
    }
    
    // Delete message
    async function deleteMessage(messageId, button) {
        Swal.fire({
            title: 'Delete Message?',
            text: 'This action cannot be undone.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: 'var(--ig-red)',
            cancelButtonColor: 'var(--ig-border)',
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'Cancel',
            background: 'var(--ig-card-bg)',
            color: 'var(--ig-text)',
            showClass: {
                popup: 'animate__animated animate__fadeInDown'
            },
            hideClass: {
                popup: 'animate__animated animate__fadeOutUp'
            }
        }).then(async (result) => {
            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/chat/message/${messageId}/delete`, {
                        method: 'DELETE',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    
                    const data = await response.json();
                    
                    if (data.success) {
                        const messageWrapper = button.closest('.message-wrapper');
                        
                        // Create bubble burst effect
                        createDeleteEffect(messageWrapper);
                        
                        // Animate deletion
                        messageWrapper.style.animation = 'deleteAnimation 0.5s ease forwards';
                        
                        setTimeout(() => {
                            messageWrapper.remove();
                            showAlert('Deleted', 'Message deleted successfully', 'success');
                        }, 500);
                    } else {
                        showAlert('Error', data.error || 'Failed to delete message', 'error');
                    }
                } catch (error) {
                    console.error('Error deleting message:', error);
                    showAlert('Error', 'Failed to delete message', 'error');
                }
            }
        });
    }
    
    // Create delete effect
    function createDeleteEffect(wrapper) {
        const rect = wrapper.getBoundingClientRect();
        const particles = 8;
        
        for (let i = 0; i < particles; i++) {
            const particle = document.createElement('div');
            particle.style.cssText = `
                position: fixed;
                width: 8px;
                height: 8px;
                background: var(--ig-gradient);
                border-radius: 50%;
                left: ${rect.left + rect.width / 2}px;
                top: ${rect.top + rect.height / 2}px;
                pointer-events: none;
                z-index: 100;
            `;
            
            document.body.appendChild(particle);
            
            const angle = (i / particles) * Math.PI * 2;
            const speed = 2;
            
            particle.animate([
                { 
                    transform: 'translate(0, 0) scale(1)',
                    opacity: 1 
                },
                { 
                    transform: `translate(${Math.cos(angle) * 100}px, ${Math.sin(angle) * 100}px) scale(0)`,
                    opacity: 0 
                }
            ], {
                duration: 800,
                easing: 'ease-out'
            });
            
            setTimeout(() => particle.remove(), 800);
        }
    }
    
    // Clear all messages
    async function clearAllMessages() {
        Swal.fire({
            title: 'Clear All Messages?',
            text: 'This will delete all messages in this chat. This action cannot be undone!',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: 'var(--ig-red)',
            cancelButtonColor: 'var(--ig-border)',
            confirmButtonText: 'Yes, clear all!',
            cancelButtonText: 'Cancel',
            background: 'var(--ig-card-bg)',
            color: 'var(--ig-text)'
        }).then(async (result) => {
            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/chat/${chatId}/clear`, {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    
                    const data = await response.json();
                    
                    if (data.success) {
                        // Animate all messages deletion
                        const messages = document.querySelectorAll('.message-wrapper');
                        messages.forEach((msg, index) => {
                            setTimeout(() => {
                                createDeleteEffect(msg);
                                msg.style.animation = 'deleteAnimation 0.5s ease forwards';
                                setTimeout(() => msg.remove(), 500);
                            }, index * 100);
                        });
                        
                        setTimeout(() => {
                            showAlert('Cleared', 'All messages cleared', 'success');
                        }, messages.length * 100 + 500);
                    }
                } catch (error) {
                    console.error('Error clearing messages:', error);
                    showAlert('Error', 'Failed to clear messages', 'error');
                }
            }
        });
    }
    
    // Download image
    function downloadImage(url) {
        const link = document.createElement('a');
        link.href = url;
        link.download = `chat-image-${Date.now()}.jpg`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
    
    // Share image
    async function shareImage() {
        if (navigator.share) {
            try {
                const imageUrl = document.getElementById('modalImage').src;
                await navigator.share({
                    title: 'Chat Image',
                    text: 'Check out this image from the chat!',
                    url: imageUrl
                });
            } catch (error) {
                console.error('Error sharing:', error);
            }
        } else {
            // Fallback: copy to clipboard
            const imageUrl = document.getElementById('modalImage').src;
            navigator.clipboard.writeText(imageUrl).then(() => {
                showAlert('Copied', 'Image URL copied to clipboard!', 'success');
            });
        }
    }
    
    // Image viewing
    function viewImage(src) {
        const modal = document.getElementById('imageModal');
        const modalImg = document.getElementById('modalImage');
        modalImg.src = src;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    
    function closeImageModal() {
        const modal = document.getElementById('imageModal');
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
    }
    
    // Close modal on escape
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeImageModal();
        }
    });
    
    // Alert helper
    function showAlert(title, text, icon) {
        Swal.fire({
            title,
            text,
            icon,
            confirmButtonColor: 'var(--ig-primary)',
            background: 'var(--ig-card-bg)',
            color: 'var(--ig-text)',
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true
        });
    }
</script>
{% endblock %}